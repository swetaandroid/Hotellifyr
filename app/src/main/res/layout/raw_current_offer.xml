<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/_130sdp"
    android:layout_marginHorizontal="@dimen/_15sdp"
    android:elevation="0dp"
    android:orientation="vertical"
    app:cardBackgroundColor="@color/colorF1F1F1"
    app:cardCornerRadius="@dimen/_20sdp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_150sdp"
            android:layout_marginEnd="@dimen/_minus2sdp"
            android:layout_toStartOf="@+id/rlStartView">

            <com.facebook.drawee.view.SimpleDraweeView
                android:id="@+id/ivIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="fitXY"
                app:actualImageResource="@drawable/ic_current_offer_1"
                app:failureImage="@drawable/ic_placeholder_rectangle"
                app:failureImageScaleType="fitXY"
                app:placeholderImage="@drawable/ic_placeholder_rectangle"
                app:placeholderImageScaleType="fitXY" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/dr_center_gradient_transparent_bg" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="@dimen/_10sdp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvTitle"
                    style="@style/Text11MediumWhite"
                    android:layout_width="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_toStartOf="@+id/ivNext"
                    android:background="@drawable/dr_black_trans_bg_20"
                    android:maxLines="2"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:paddingVertical="@dimen/_3sdp"
                    android:singleLine="false"
                    android:text="Discover our brand new hotels" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivNext"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_15sdp"
                    android:src="@drawable/ic_next" />

            </RelativeLayout>

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/rlStartView"
            android:layout_width="@dimen/_55sdp"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/contentLayout"
            android:layout_alignBottom="@+id/contentLayout"
            android:layout_alignParentEnd="true"
            android:background="@drawable/ic_bg_offer"
            android:gravity="center"
            android:paddingHorizontal="@dimen/_4sdp"
            android:paddingVertical="@dimen/_10sdp">

            <com.xongolab.hotellifyr.custom.VerticalTextView
                android:id="@+id/tvCouponDiscount"
                style="@style/Text10MediumBlack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="bottom|center"
                android:singleLine="false"
                android:text="20  d  16  h left"
                android:textColor="@color/colorSecondary" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="@dimen/_20sdp"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="@dimen/_45sdp"
            android:orientation="vertical">

            <View
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_marginTop="@dimen/_minus12sdp"
                android:background="@drawable/dr_gray_circle" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <View
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_gravity="bottom"
                android:layout_marginBottom="@dimen/_minus12sdp"
                android:background="@drawable/dr_gray_circle" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>