<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".view.activity.home.ConfirmPayActivity">

    <include
        android:id="@+id/toolbar"
        layout="@layout/main_toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/_10sdp"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_4sdp"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/_10sdp">

                <com.facebook.drawee.view.SimpleDraweeView
                    android:layout_width="@dimen/_80sdp"
                    android:layout_height="@dimen/_60sdp"
                    android:scaleType="fitXY"
                    app:actualImageResource="@drawable/ic_hot_selling_1"
                    app:roundedCornerRadius="@dimen/_10sdp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text12MediumBlack"
                        android:singleLine="false"
                        android:text="Signature Suite" />

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text10RegularBlack"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:singleLine="false"
                        android:text="Tue, 23 July - Thu, 25 July" />

                    <androidx.appcompat.widget.AppCompatTextView
                        style="@style/Text10RegularBlack"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:singleLine="false"
                        android:text="1 Room, 2 Guest" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text12MediumBlack"
                    android:layout_width="wrap_content"
                    android:text="@string/total_stay" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text10MediumBlack"
                    android:layout_width="wrap_content"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:text="(3 Days &amp; 2 Nights )" />

            </LinearLayout>

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text16MediumSecondary"
                android:layout_width="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:includeFontPadding="false"
                android:text="26,082.00 INR" />

            <com.xongolab.hotellifyr.custom.RoundableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_15sdp"
                app:cornerAll="@dimen/_15sdp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ic_card_bg">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/_15sdp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="bottom"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    style="@style/Text12RegularWhite"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:text="@string/credit_card" />

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="@dimen/_35sdp"
                                    android:layout_height="@dimen/_25sdp"
                                    android:src="@drawable/ic_master_card" />

                            </LinearLayout>

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="@dimen/_40sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_marginTop="@dimen/_15sdp"
                                android:scaleType="fitStart"
                                android:src="@drawable/ic_card_chip" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tvCardType"
                                style="@style/Text12RegularWhite"
                                android:layout_width="wrap_content"
                                android:layout_marginTop="@dimen/_15sdp"
                                android:includeFontPadding="false"
                                android:text="2021 0213 2025 2591" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_5sdp"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    style="@style/Text10RegularWhite"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/product_sans_regular"
                                    android:text="Jennifer Stiffler" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    style="@style/Text10RegularWhite"
                                    android:layout_width="wrap_content"
                                    android:fontFamily="@font/product_sans_regular"
                                    android:text="@string/exp" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    style="@style/Text14RegularWhite"
                                    android:layout_width="wrap_content"
                                    android:layout_marginStart="@dimen/_2sdp"
                                    android:fontFamily="@font/product_sans_regular"
                                    android:text="12/25" />

                            </LinearLayout>

                        </LinearLayout>

                    </RelativeLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.xongolab.hotellifyr.custom.RoundableLayout>

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnConfirmPay"
            style="@style/ButtonBlackStyle"
            android:layout_marginVertical="@dimen/_15sdp"
            android:fontFamily="@font/product_sans_regular"
            android:text="@string/confirm_amp_pay_26_082_00_inr" />

    </LinearLayout>

</LinearLayout>