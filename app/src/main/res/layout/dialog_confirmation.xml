<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dr_white_bg_15"
    android:orientation="vertical"
    android:padding="@dimen/_16ssp">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvMessage"
        style="@style/Text14MediumBlack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:gravity="center"
        android:singleLine="false"
        android:text="@string/are_you_sure_you_want_to_remove_this_hotel_from_your_wishlist" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvMessage"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="@dimen/_20sdp"
        android:orientation="horizontal"
        android:weightSum="2">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvCancel"
            style="@style/SmallButtonPrimaryBorderStyle"
            android:layout_marginEnd="@dimen/_4sdp"
            android:layout_weight="1"
            android:paddingVertical="@dimen/_6sdp"
            android:text="@string/cancel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvConfirm"
            style="@style/ButtonPrimaryStyle"
            android:layout_marginStart="@dimen/_4sdp"
            android:layout_weight="1"
            android:background="@drawable/dr_primary_bg_6"
            android:paddingVertical="@dimen/_6sdp"
            android:text="@string/confirm" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</RelativeLayout>