<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/_8sdp"
    android:layout_marginEnd="@dimen/_10sdp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivCheck"
        android:layout_width="@dimen/_15sdp"
        android:layout_height="@dimen/_15sdp"
        android:src="@drawable/cb_uncheck" />

    <com.facebook.drawee.view.SimpleDraweeView
        android:id="@+id/ivAmenities"
        android:layout_width="@dimen/_20sdp"
        android:visibility="gone"
        android:layout_height="@dimen/_20sdp"
        android:layout_marginHorizontal="@dimen/_8sdp"
        android:src="@drawable/ic_business_center_secondary"
        app:failureImage="@drawable/ic_placeholder_rectangle"
        app:placeholderImage="@drawable/ic_placeholder_rectangle" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvTitle"
        style="@style/Text10RegularBlack"
        android:maxLines="2"
        android:layout_marginStart="@dimen/_8sdp"
        android:singleLine="false"
        android:text="Amenities" />

</LinearLayout>