<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorWhite"
    android:orientation="vertical"
    android:paddingBottom="@dimen/_15sdp"
    tools:context=".view.activity.account.subscription.PioneerMemberActivity">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="@dimen/_260sdp"
        android:background="@drawable/ic_pioneer_member_top_bg"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/rlToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:paddingHorizontal="@dimen/_10sdp"
            android:paddingBottom="@dimen/_15sdp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/_35sdp"
                android:layout_height="@dimen/_35sdp"
                android:layout_alignParentStart="true"
                android:layout_marginTop="@dimen/_20sdp"
                android:padding="@dimen/_8sdp"
                android:src="@drawable/ic_back_white_arrow" />

            <RelativeLayout
                android:id="@+id/rlProfile"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/_30sdp"
                android:background="@drawable/dr_dark_gray_circle"
                android:backgroundTint="@color/colorWhite"
                android:padding="@dimen/_2sdp">

                <!-- <de.hdodenhof.circleimageview.CircleImageView
                     android:layout_width="match_parent"
                     android:layout_height="match_parent"
                     android:layout_centerInParent="true"
                     android:scaleType="fitXY"
                     android:src="@drawable/ic_dummy_user" />-->

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/profile_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_dummy_user" />

            </RelativeLayout>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/icSetting"
                android:layout_width="@dimen/_35sdp"
                android:layout_height="@dimen/_35sdp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="@dimen/_20sdp"
                android:padding="@dimen/_8sdp"
                android:src="@drawable/ic_setting_white" />

        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvUserName"
            style="@style/Text14MediumBlack"
            android:layout_below="@id/rlToolbar"
            android:gravity="center"
            android:text="Jennifer Stiffler" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvPioneerMember"
            style="@style/Text10RegularBlack"
            android:layout_below="@id/tvUserName"
            android:layout_marginTop="@dimen/_6sdp"
            android:gravity="center"
            android:text="@string/pioneer_member" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTotal"
            style="@style/Text20MediumBlack"
            android:layout_below="@id/tvPioneerMember"
            android:layout_marginTop="@dimen/_15sdp"
            android:gravity="center"
            android:text="20,000"
            android:textSize="@dimen/_24ssp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvAvailablePoints"
            style="@style/Text12RegularBlack"
            android:layout_below="@id/tvTotal"
            android:layout_marginTop="@dimen/_6sdp"
            android:gravity="center"
            android:text="@string/available_points" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tvAvailablePoints"
            android:background="@color/colorWhite"
            android:orientation="vertical"
            android:paddingTop="@dimen/_20sdp">

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text14MediumBlack"
                android:layout_below="@id/rlToolbar"
                android:layout_marginHorizontal="@dimen/_15sdp"
                android:text="@string/what_s_coming_up" />

            <include
                android:id="@+id/llRewardCircle"
                layout="@layout/layout_reward_circle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvNewlyOpened"
                    style="@style/Text14MediumBlack"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/newly_opened" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvNewlyOpenedSeeAll"
                    style="@style/Text14MediumSecondary"
                    android:layout_width="wrap_content"
                    android:text="@string/see_all" />

            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNewlyOpened"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_14sdp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="3"
                tools:listitem="@layout/raw_newly_opened_pioneer_member" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text14MediumBlack"
                android:layout_margin="@dimen/_15sdp"
                android:text="@string/pioneer_member_discount" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMemberDiscount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="3"
                tools:listitem="@layout/raw_pioneer_member_discount" />

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.core.widget.NestedScrollView>

</androidx.appcompat.widget.LinearLayoutCompat>
