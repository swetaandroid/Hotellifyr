<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".view.activity.account.MemberBenefitsDetailsActivity">

    <include
        android:id="@+id/toolBar"
        layout="@layout/normal_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_8sdp"
        android:layout_marginTop="@dimen/_10sdp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text12RegularBlack"
                android:layout_width="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="@string/become_a" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text20BoldBlack"
                android:layout_width="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:includeFontPadding="false"
                android:text="@string/pioneer_member" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text12RegularGray"
                android:layout_width="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:gravity="center_horizontal"
                android:includeFontPadding="false"
                android:paddingHorizontal="@dimen/_25sdp"
                android:singleLine="false"
                android:text="@string/member_benefits_desc" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_220sdp"
                android:layout_marginTop="@dimen/_30sdp"
                android:paddingHorizontal="@dimen/_60sdp" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_20sdp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@color/colorTransparent"
                app:tabBackground="@drawable/dr_tab_pager_indicator"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabPaddingBottom="0dp"
                app:tabPaddingEnd="@dimen/_5sdp"
                app:tabPaddingStart="@dimen/_5sdp"
                app:tabPaddingTop="0dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btnSubscribeNow"
                style="@style/ButtonPrimaryStyle"
                android:layout_marginHorizontal="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_30sdp"
                android:text="@string/subscribe_now" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>