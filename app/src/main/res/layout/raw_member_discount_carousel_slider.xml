<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="@dimen/_2sdp"
    android:orientation="vertical"
    app:cardCornerRadius="@dimen/_20sdp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/_6sdp"
            android:background="@color/colorWhite"
            android:orientation="vertical">

            <com.xongolab.hotellifyr.custom.RoundableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cornerLeftTop="@dimen/_20sdp"
                app:cornerRightTop="@dimen/_20sdp">

                <com.facebook.drawee.view.SimpleDraweeView
                    android:id="@+id/ivProfile"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_130sdp"
                    android:scaleType="fitXY"
                    app:actualImageResource="@drawable/ic_banner_1"
                    app:roundTopEnd="false"
                    app:roundTopLeft="false"
                    app:roundedCornerRadius="@dimen/_20sdp" />

            </com.xongolab.hotellifyr.custom.RoundableLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/Text13MediumBlack"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:maxLines="2"
                android:singleLine="false"
                android:text="Royal Orchid Beach Resort &amp; Spa, Jaipur" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:src="@drawable/ic_location_primary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvGuest"
                    style="@style/Text12RegularPrimary"
                    android:layout_width="wrap_content"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:text="Jaipur" />

            </LinearLayout>

        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="@dimen/_20sdp"
            android:background="@drawable/ic_discount_badge">

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text14BoldBlack"
                android:layout_width="wrap_content"
                android:includeFontPadding="false"
                android:paddingHorizontal="@dimen/_15sdp"
                android:paddingVertical="@dimen/_10sdp"
                android:singleLine="false"
                android:text="50% off"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>