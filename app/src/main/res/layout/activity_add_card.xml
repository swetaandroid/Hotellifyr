<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".view.activity.home.AddCardActivity">

    <include
        android:id="@+id/toolbar"
        layout="@layout/main_toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/_15sdp">

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text12RegularBlack"
                    android:singleLine="false"
                    android:text="@string/card_number" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/edtCardNumber"
                    style="@style/EditTextParentStyle"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:background="@drawable/dr_light_gray_bg"
                    android:hint="0000 0000 0000 0000"
                    android:imeOptions="actionNext"
                    android:inputType="phone"
                    android:maxLength="19"
                    android:textColorHint="@color/colorBlack" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text12RegularBlack"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:singleLine="false"
                    android:text="@string/card_type" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:background="@drawable/dr_light_gray_bg"
                    android:gravity="center_vertical"
                    android:padding="@dimen/_12sdp">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvCardType"
                        style="@style/Text12RegularBlack"
                        android:layout_toStartOf="@+id/ivCardTypeArrow"
                        android:singleLine="false"
                        android:text="@string/card_type" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivCardTypeArrow"
                        android:layout_width="@dimen/_10sdp"
                        android:layout_height="@dimen/_10sdp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/_4sdp"
                        android:src="@drawable/ic_down_arrow_black" />

                </RelativeLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text12RegularBlack"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:singleLine="false"
                    android:text="@string/name_on_card" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/edtName"
                    style="@style/EditTextParentStyle"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:background="@drawable/dr_light_gray_bg"
                    android:hint="@string/name_on_card"
                    android:imeOptions="actionNext"
                    android:inputType="textPersonName"
                    android:textColorHint="@color/colorBlack" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.AppCompatTextView
                            style="@style/Text12RegularBlack"
                            android:singleLine="false"
                            android:text="@string/expirations_date" />

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edtExpiryDate"
                            style="@style/EditTextParentStyle"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:background="@drawable/dr_light_gray_bg"
                            android:hint="MM/YY"
                            android:imeOptions="actionNext"
                            android:inputType="phone"
                            android:maxLength="5"
                            android:textColorHint="@color/colorBlack" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_15sdp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.AppCompatTextView
                            style="@style/Text12RegularBlack"
                            android:singleLine="false"
                            android:text="@string/postal_code" />

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edtPostalCode"
                            style="@style/EditTextParentStyle"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:background="@drawable/dr_light_gray_bg"
                            android:hint="@string/postal_code"
                            android:imeOptions="actionDone"
                            android:inputType="number"
                            android:maxLength="3"
                            android:textColorHint="@color/colorBlack" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnDone"
            style="@style/ButtonPrimaryStyle"
            android:layout_margin="@dimen/_15sdp"
            android:text="@string/done" />

    </LinearLayout>

</LinearLayout>