<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvPreferencesTitle"
        style="@style/Text12RegularBlack"
        android:layout_width="wrap_content"
        android:layout_centerVertical="true"
        tools:text="@string/room"
        android:layout_marginTop="@dimen/_15sdp"/>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icArrowRoom"
        android:layout_width="@dimen/_20sdp"
        android:layout_height="@dimen/_20sdp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_gray_back_arrow"
        android:layout_marginTop="@dimen/_15sdp"/>

    <View style="@style/ViewBorderStyle"
        android:layout_below="@id/icArrowRoom"
        android:layout_marginTop="@dimen/_15sdp"/>

</RelativeLayout>