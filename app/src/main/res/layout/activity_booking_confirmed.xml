<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yourAccentColor"
    android:orientation="vertical"
    android:paddingTop="@dimen/_40sdp"
    tools:context=".view.activity.home.BookingConfirmedActivity">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btnBack"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_30sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:padding="@dimen/_5sdp"
        android:src="@drawable/ic_back_white_arrow" />

    <LinearLayout
        android:id="@+id/llTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_45sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:gravity="center"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_35sdp"
            android:src="@drawable/ic_booking_confirmed" />

        <androidx.appcompat.widget.AppCompatTextView
            style="@style/Text18BoldWhite"
            android:layout_marginTop="@dimen/_10sdp"
            android:gravity="center"
            android:text="@string/aaawesome" />

        <androidx.appcompat.widget.AppCompatTextView
            style="@style/Text14BoldWhite"
            android:gravity="center"
            android:text="@string/your_booking_is_confirmed" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvBookingId"
            style="@style/Text10RegularGray"
            android:gravity="center"
            android:text="Booking Reference No : 947NHGT354"
            android:textColor="@color/colorOutLine" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/llTop"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_30sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:background="@drawable/dr_white_bg_15"
        android:orientation="vertical">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/_120sdp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_40sdp">

                <com.xongolab.hotellifyr.custom.CustomRatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    app:emptyStar="@drawable/ic_star_empty"
                    app:filledStar="@drawable/ic_star_fill"
                    app:maxRating="5"
                    app:rate="false"
                    app:rating="5"
                    app:starSize="@dimen/_15sdp"
                    app:starSpacing="@dimen/_5sdp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvHotelName"
                    style="@style/Text14MediumBlack"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:gravity="center"
                    android:singleLine="false"
                    android:text="Royal Orchid Beach Resort &amp; Spa, Goa" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvHotelAddress"
                    style="@style/Text10RegularGray"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:gravity="center"
                    android:singleLine="false"
                    android:visibility="gone"
                    tools:text="Utorda Beach Rd, Utarda, Goa 403713" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_weight="1"
                        android:background="@drawable/dr_light_gray_border_10"
                        android:orientation="vertical"
                        android:padding="@dimen/_10sdp">

                        <androidx.appcompat.widget.AppCompatTextView
                            style="@style/Text10MediumBlack"
                            android:gravity="center"
                            android:singleLine="false"
                            android:text="Check In" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvCheckInDate"
                            style="@style/Text22MediumPrimary"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:singleLine="false"
                            android:text="23"
                            android:textSize="@dimen/_24ssp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvCheckInDay"
                            style="@style/Text10RegularBlack"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:gravity="center"
                            android:singleLine="false"
                            android:text="Tuesday, July" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_8sdp"
                        android:layout_weight="1"
                        android:background="@drawable/dr_light_gray_border_10"
                        android:orientation="vertical"
                        android:padding="@dimen/_10sdp">

                        <androidx.appcompat.widget.AppCompatTextView
                            style="@style/Text10MediumBlack"
                            android:gravity="center"
                            android:singleLine="false"
                            android:text="Check Out" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvCheckOutDate"
                            style="@style/Text22MediumPrimary"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:singleLine="false"
                            android:text="25"
                            android:textSize="@dimen/_24ssp" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvCheckOutDay"
                            style="@style/Text10RegularBlack"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:gravity="center"
                            android:singleLine="false"
                            android:text="Tuesday, July" />

                    </LinearLayout>

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPackage"
                    style="@style/Text12MediumBlack"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:gravity="center"
                    android:singleLine="false"
                    tools:text="3 Days &amp; 2 Nights (1 Room, 2 Guest)" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_marginStart="@dimen/_minus10sdp"
                android:src="@drawable/dr_black_circle" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_centerVertical="true"
                android:background="@drawable/dr_black_dotted_line" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="@dimen/_minus10sdp"
                android:src="@drawable/dr_black_circle" />

        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnShareNow"
            style="@style/ButtonPrimaryStyle"
            android:layout_marginHorizontal="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_20sdp"
            android:text="@string/share_now" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_140sdp"
        android:layout_below="@+id/llTop"
        android:layout_marginHorizontal="@dimen/_50sdp"
        app:cardCornerRadius="@dimen/_10sdp">

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/ivIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            app:actualImageResource="@drawable/ic_booking_hotel" />

    </androidx.cardview.widget.CardView>

</RelativeLayout>