<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/_130sdp"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/_3sdp"
    android:layout_marginEnd="@dimen/_10sdp"
    android:background="@drawable/dr_white_bg_12"
    android:backgroundTint="@color/colorWhite"
    android:elevation="@dimen/_2sdp"
    android:orientation="vertical"
    android:padding="@dimen/_10sdp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_120sdp"
        android:elevation="@dimen/_2sdp"
        app:cardCornerRadius="@dimen/_12sdp">

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/ivIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            app:actualImageResource="@drawable/ic_placeholder_square"
            app:failureImage="@drawable/ic_placeholder_square"
            app:failureImageScaleType="fitXY"
            app:placeholderImageScaleType="fitXY" />

    </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvTitle"
        style="@style/Text10MediumBlack"
        android:layout_gravity="center_vertical"
        android:layout_marginTop="@dimen/_15sdp"
        android:text="Britto's Restaurant" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvDesc"
            style="@style/Text9RegularGray"
            android:layout_width="0dp"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:maxLines="2"
            android:singleLine="false"
            android:text="Britto's Restaurant" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/icArrow"
            android:layout_width="@dimen/_15sdp"
            android:layout_height="@dimen/_15sdp"
            android:layout_marginStart="@dimen/_2sdp"
            android:src="@drawable/ic_back_arrow_gray" />

    </LinearLayout>

</LinearLayout>