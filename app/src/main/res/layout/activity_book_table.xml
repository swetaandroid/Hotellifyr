<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".view.activity.home.search.hotel.BookTableActivity">

    <com.xongolab.hotellifyr.custom.RoundableLayout
        android:id="@+id/roundLayout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_65sdp"
        android:layout_alignParentTop="true"
        android:elevation="@dimen/_3sdp"
        app:cornerLeftBottom="@dimen/_30sdp"
        app:cornerRightBottom="@dimen/_30sdp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/_10sdp"
            android:paddingVertical="@dimen/_10sdp">

            <RelativeLayout
                android:id="@+id/rlToolBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/btnBack"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/ic_back_black_arrow" />

                <androidx.appcompat.widget.AppCompatTextView
                    style="@style/Text16BoldBlack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="@string/book_a_table" />

            </RelativeLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvHotelName"
                style="@style/Text12RegularGray"
                android:layout_below="@+id/rlToolBar"
                android:layout_marginHorizontal="@dimen/_15sdp"
                android:gravity="center"
                android:text="Britto's Restaurant" />

        </RelativeLayout>

    </com.xongolab.hotellifyr.custom.RoundableLayout>

    <LinearLayout
        android:id="@+id/llDateView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/roundLayout"
        android:layout_centerHorizontal="true"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_15sdp"
        android:orientation="horizontal">

        <RelativeLayout
            android:id="@+id/llDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_5sdp"
            android:layout_weight="1"
            android:background="@drawable/dr_primary_border_5"
            android:backgroundTint="@color/colorOffWhite"
            android:paddingHorizontal="@dimen/_10sdp"
            android:paddingVertical="@dimen/_8sdp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivDate"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_calendar_white"
                android:tint="@color/colorSecondary" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDate"
                style="@style/Text12RegularBlack"
                android:layout_centerVertical="true"
                android:layout_marginHorizontal="@dimen/_5sdp"
                android:layout_toStartOf="@+id/ivDateDown"
                android:layout_toEndOf="@+id/ivDate"
                android:text="Tue, 23 July" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivDateDown"
                android:layout_width="@dimen/_10sdp"
                android:layout_height="@dimen/_10sdp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_down_arrow_black" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_weight="1"
            android:orientation="vertical">

            <RelativeLayout
                android:id="@+id/llGuest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dr_primary_border_5"
                android:backgroundTint="@color/colorOffWhite"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_10sdp"
                android:paddingVertical="@dimen/_8sdp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivGuest"
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_person_white"
                    android:tint="@color/colorSecondary" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvGuest"
                    style="@style/Text12RegularBlack"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:layout_toStartOf="@+id/ivGuestDown"
                    android:layout_toEndOf="@+id/ivGuest"
                    android:text="0 Guests" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivGuestDown"
                    android:layout_width="@dimen/_10sdp"
                    android:layout_height="@dimen/_10sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_down_arrow_black" />

            </RelativeLayout>

            <com.xongolab.hotellifyr.custom.CustomSpinner
                android:id="@+id/spGuest"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@null" />

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/llDateView">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_15sdp"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text14BoldBlack"
                android:text="@string/select_time" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOuterTimeSlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_60sdp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="1"
                tools:listitem="@layout/raw_outer_time_slot" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/btnConfirmReservation"
        style="@style/ButtonParentStyle"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_20sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:backgroundTint="@color/colorOutLine"
        android:text="@string/confirm_reservation" />

</RelativeLayout>