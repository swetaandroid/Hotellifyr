<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.activity.account.ConfirmIdentityActivity">

    <include
        android:id="@+id/layoutToolBar"
        layout="@layout/normal_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_8sdp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/btnSendCode"
        android:layout_below="@id/layoutToolBar"
        android:fillViewport="true">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_15sdp">

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/Text12RegularGray"
                android:singleLine="false"
                android:text="@string/confirm_identity_desc" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/edtCode"
                style="@style/EditTextParentStyle"
                android:layout_marginTop="@dimen/_15sdp"
                android:background="@drawable/dr_light_gray_bg"
                android:text="Jennifer Stiffler" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvResendCode"
                style="@style/Text12RegularSecondary"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="@string/resend_code"
                android:visibility="gone" />

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/btnSendCode"
        style="@style/ButtonParentStyle"
        android:layout_alignParentBottom="true"
        android:layout_margin="@dimen/_15sdp"
        android:text="@string/send_code" />

</RelativeLayout>
