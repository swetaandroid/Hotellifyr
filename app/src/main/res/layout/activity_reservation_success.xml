<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yourAccentColor"
    android:orientation="vertical"
    android:paddingTop="@dimen/_30sdp"
    tools:context=".view.activity.home.search.hotel.ReservationSuccessActivity">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btnBack"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_30sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:padding="@dimen/_5sdp"
        android:src="@drawable/ic_back_white_arrow" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/llTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_45sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:gravity="center"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_35sdp"
            android:src="@drawable/ic_reservation_success" />

        <androidx.appcompat.widget.AppCompatTextView
            style="@style/Text18BoldWhite"
            android:layout_marginTop="@dimen/_10sdp"
            android:gravity="center"
            android:text="@string/aaawesome" />

        <androidx.appcompat.widget.AppCompatTextView
            style="@style/Text14BoldWhite"
            android:gravity="center"
            android:text="@string/your_booking_is_confirmed" />


    </androidx.appcompat.widget.LinearLayoutCompat>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/llTop"
        android:layout_marginHorizontal="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_30sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:background="@drawable/dr_white_bg_15"
        android:orientation="vertical">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/_80sdp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_40sdp">

                <com.xongolab.hotellifyr.custom.CustomRatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    app:emptyStar="@drawable/ic_star_empty"
                    app:filledStar="@drawable/ic_star_fill"
                    app:maxRating="5"
                    app:rate="false"
                    app:rating="5"
                    app:starSize="@dimen/_15sdp"
                    app:starSpacing="@dimen/_5sdp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvName"
                    style="@style/Text14MediumBlack"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:gravity="center"
                    android:text="Britto's Restaurant" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvTag"
                    style="@style/Text10RegularGray"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:gravity="center"
                    android:text="Indian • Multi Cuisine" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvLocation"
                    style="@style/Text10RegularGray"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:gravity="center"
                    android:text="Utorda Beach Rd, Utarda, Goa 403713" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/dr_light_gray_border_10"
                        android:orientation="vertical"
                        android:padding="@dimen/_10sdp">

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatTextView
                                style="@style/Text12BoldBlack"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/date" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tvDate"
                                style="@style/Text12BoldPrimary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tue, 23 July" />


                        </androidx.appcompat.widget.LinearLayoutCompat>

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatTextView
                                style="@style/Text12BoldBlack"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/time" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tvTime"
                                style="@style/Text12BoldPrimary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="11:30 am" />

                        </androidx.appcompat.widget.LinearLayoutCompat>

                    </LinearLayout>

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvAdults"
                    style="@style/Text12MediumBlack"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:gravity="center"
                    android:text="4 Adult(s)" />

            </LinearLayout>


        </androidx.core.widget.NestedScrollView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_marginStart="@dimen/_minus10sdp"
                android:src="@drawable/dr_black_circle" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_centerVertical="true"
                android:background="@drawable/dr_black_dotted_line" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="@dimen/_minus10sdp"
                android:src="@drawable/dr_black_circle" />

        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnShareNow"
            style="@style/ButtonPrimaryStyle"
            android:layout_marginHorizontal="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_20sdp"
            android:text="@string/share_now" />


    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_100sdp"
        android:layout_below="@+id/llTop"
        android:layout_marginHorizontal="@dimen/_50sdp"
        app:cardCornerRadius="@dimen/_10sdp">

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/ivIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            app:actualImageResource="@drawable/img_reservation_success"
            app:failureImage="@drawable/ic_placeholder_rectangle"
            app:placeholderImage="@drawable/ic_placeholder_rectangle" />

    </androidx.cardview.widget.CardView>


</RelativeLayout>









