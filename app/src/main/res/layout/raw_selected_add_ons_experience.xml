<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/llOnsExperienceAdded"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/_1sdp"
    android:layout_marginVertical="@dimen/_4sdp"
    android:visibility="visible"
    app:cardCornerRadius="@dimen/_10sdp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/_5sdp">

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/ivIcon"
            android:layout_width="@dimen/_80sdp"
            android:layout_height="@dimen/_60sdp"
            android:scaleType="fitXY"
            app:actualImageResource="@drawable/ic_hot_selling_1"
            app:failureImage="@drawable/ic_placeholder_rectangle"
            app:placeholderImage="@drawable/ic_placeholder_rectangle"
            app:roundedCornerRadius="@dimen/_10sdp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_5sdp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:alignItems="flex_start"
                app:flexWrap="wrap"
                app:justifyContent="space_between">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPackage"
                    style="@style/Text10BoldBlack"
                    android:layout_width="0dp"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:singleLine="false"
                    android:text="Gold+ (Package)" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvPrice"
                    style="@style/Text10BoldPrimary"
                    android:layout_width="wrap_content"
                    android:singleLine="false"
                    android:text="3,500.00 INR" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvTitle"
                        style="@style/Text10RegularGray"
                        android:layout_marginTop="@dimen/_2sdp"
                        android:text="Scuba Diving At Grand Island"
                        android:textSize="@dimen/_8ssp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvPackageTitle"
                        style="@style/Text10RegularBlack"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="+ 9 Water Sports | Bestselling Combo"
                        android:textSize="@dimen/_8ssp" />

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivDelete"
                    android:layout_width="@dimen/_15sdp"
                    android:layout_height="@dimen/_15sdp"
                    android:layout_gravity="bottom"
                    android:src="@drawable/ic_delete" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
