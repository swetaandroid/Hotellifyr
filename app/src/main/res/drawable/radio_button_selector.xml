<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- SELECTED -->
    <item android:state_checked="true">
        <layer-list>
            <!-- Outer Ring -->
            <item>
                <shape android:shape="oval">
                    <size android:width="@dimen/_24sdp" android:height="@dimen/_24sdp"/>
                    <stroke android:width="@dimen/_2sdp" android:color="@color/colorPrimary"/>
                    <solid android:color="#00FFFFFF"/>
                </shape>
            </item>

            <!-- Inner Circle -->
            <item android:bottom="@dimen/_4sdp" android:top="@dimen/_4sdp" android:left="@dimen/_4sdp" android:right="@dimen/_4sdp">
                <shape android:shape="oval">
                    <solid android:color="@color/colorPrimary"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- UNSELECTED -->
    <item>
        <shape android:shape="oval">
            <size android:width="@dimen/_24sdp" android:height="@dimen/_24sdp"/>
            <stroke android:width="@dimen/_2sdp" android:color="@color/colorSecondary"/>
            <solid android:color="#00FFFFFF"/>
        </shape>
    </item>

</selector>
